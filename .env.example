# shan-field-app environment template.
#
# Copy to `.env` (untracked) and fill in. Expo SDK 49+ loads .env
# automatically; any variable prefixed with EXPO_PUBLIC_ is exposed
# to the client bundle, so anything sensitive must NOT live here —
# it would ship inside the APK. The Firebase web config is fine to
# expose (it's all public-facing keys; the gate is Firebase Auth
# rules, not the apiKey).

# ─── Backend ──────────────────────────────────────────────────────
# Points at the live Render service in prod; switch to your laptop
# IP for local backend dev (e.g. http://192.168.1.20:1234).
EXPO_PUBLIC_API_BASE=https://doc-gen-ola-hiveforce.onrender.com

# ─── Firebase ─────────────────────────────────────────────────────
# Same values your web app uses — copy from packages/accounting-app
# .env. These are the project's public Web SDK config (not the
# service-account JSON the backend uses).
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=
